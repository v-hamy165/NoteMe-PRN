<Window x:Class="NoteMe.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - Đăng nhập"
        Height="550"
        Width="420"
        MinHeight="550"
        MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        Loaded="Window_Loaded">

    <Grid>
        <!-- Nền dải màu Gradient Hiện đại -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0.0"/>
                <GradientStop Color="#1E293B" Offset="0.6"/>
                <GradientStop Color="#2563EB" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Thẻ đăng nhập bo góc và đổ bóng -->
        <Border Background="White"
                CornerRadius="12"
                Width="340"
                Height="450"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.25" Color="#000000"/>
            </Border.Effect>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header / Logo -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <TextBlock Text="📝 NoteMe"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#3B82F6"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtFormSubtitle"
                               Text="Đăng nhập tài khoản của bạn"
                               FontSize="12"
                               Foreground="#64748B"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Form Inputs -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Tên đăng nhập"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtUsername"
                             Height="38"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Mật khẩu"
                               FontSize="12.5"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"/>

                    <StackPanel x:Name="registerFields" Visibility="Collapsed">
                        <TextBlock Text="Xác nhận mật khẩu"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,6,0,6"/>
                        <PasswordBox x:Name="txtConfirmPassword"
                                     Height="38"
                                     VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Đăng nhập / Đăng ký -->
                <StackPanel Grid.Row="2" Margin="0,10,0,4">
                    <Button x:Name="btnLogin"
                            Content="Đăng nhập"
                            Height="42"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Background="#3B82F6"
                            Foreground="White"
                            Margin="0,0,0,8"
                            Click="btnLogin_Click"/>

                    <Button x:Name="btnShowRegister"
                            Content="Chưa có tài khoản? Đăng ký"
                            Height="38"
                            Background="#E2E8F0"
                            Foreground="#334155"
                            Click="btnShowRegister_Click"/>

                    <Button x:Name="btnRegister"
                            Content="Đăng ký tài khoản"
                            Height="42"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Background="#10B981"
                            Foreground="White"
                            Margin="0,0,0,8"
                            Visibility="Collapsed"
                            Click="btnRegister_Click"/>

                    <Button x:Name="btnBackToLogin"
                            Content="Quay lại đăng nhập"
                            Height="38"
                            Background="#E2E8F0"
                            Foreground="#334155"
                            Visibility="Collapsed"
                            Click="btnBackToLogin_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
