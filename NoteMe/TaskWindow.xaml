<Window x:Class="NoteMe.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - Việc cần làm" Height="700" Width="1080" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9" Loaded="Window_Loaded">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#0F172A" CornerRadius="10" Padding="18,14" Margin="0,0,0,14">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Việc cần làm" FontSize="22" FontWeight="Bold" Foreground="White"/><TextBlock x:Name="txtSummary" Foreground="#CBD5E1" Margin="0,3,0,0"/></StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ Tạo công việc" Width="130" Height="36" Background="#10B981" Foreground="White" FontWeight="Bold" Click="btnAdd_Click"/>
                    <Button Content="Làm mới" Width="90" Height="36" Margin="8,0,0,0" Click="btnRefresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        <TabControl Grid.Row="1" Background="White" BorderBrush="#CBD5E1">
            <TabItem Header="  Danh sách  ">
                <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Trạng thái:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cboStatusFilter" Width="170" Height="34" Margin="8,0,0,0" SelectionChanged="cboStatusFilter_SelectionChanged"/>
                        <CheckBox x:Name="chkHideCompleted" Content="Ẩn việc đã hoàn thành" Margin="20,0,0,0" VerticalAlignment="Center" Checked="filter_Changed" Unchecked="filter_Changed"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="dgTasks" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="dgTasks_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Công việc" Binding="{Binding Title}" Width="2.4*"/>
                            <DataGridTextColumn Header="Hạn" Binding="{Binding DueDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="145"/>
                            <DataGridTextColumn Header="Ưu tiên" Binding="{Binding PriorityDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusDisplay}" Width="115"/>
                            <DataGridTextColumn Header="Nguồn" Binding="{Binding SourceDisplay}" Width="1.3*"/>
                            <DataGridTextColumn Header="Nhắc lúc" Binding="{Binding ReminderAt, StringFormat={}{0:dd/MM HH:mm}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Đánh dấu hoàn thành" Width="165" Height="36" Background="#16A34A" Foreground="White" Click="btnComplete_Click"/>
                        <Button Content="Sửa" Width="90" Height="36" Margin="8,0,0,0" Background="#2563EB" Foreground="White" Click="btnEdit_Click"/>
                        <Button Content="Xóa" Width="90" Height="36" Margin="8,0,0,0" Background="#DC2626" Foreground="White" Click="btnDelete_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="  Lịch  ">
                <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Calendar x:Name="calendar" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" SelectionMode="SingleDate" SelectedDatesChanged="calendar_SelectedDatesChanged"/>
                    <Border Grid.Column="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="14">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock x:Name="txtCalendarDate" FontSize="17" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                            <DataGrid Grid.Row="1" x:Name="dgCalendarTasks" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns><DataGridTextColumn Header="Công việc" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="Giờ" Binding="{Binding DueDate, StringFormat={}{0:HH:mm}}" Width="70"/><DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusDisplay}" Width="110"/></DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
