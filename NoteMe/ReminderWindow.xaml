<Window x:Class="NoteMe.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhắc lịch" Width="390" Height="260" WindowStyle="None" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True" Background="Transparent" AllowsTransparency="True">
    <Border Background="#0F172A" CornerRadius="12" Padding="18" BorderBrush="#334155" BorderThickness="1">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel><TextBlock Text="🔔 Công việc sắp đến hạn" Foreground="White" FontWeight="Bold" FontSize="17"/><TextBlock Text="NoteMe nhắc bạn:" Foreground="#CBD5E1" Margin="0,4,0,10"/></StackPanel>
            <ListBox Grid.Row="1" x:Name="lstReminders" Background="Transparent" BorderThickness="0" Foreground="White">
                <ListBox.ItemTemplate><DataTemplate><StackPanel Margin="0,4"><TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/><TextBlock Text="{Binding DueDate, StringFormat='Hạn: {0:dd/MM/yyyy HH:mm}'}" Foreground="#FBBF24" FontSize="12"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><Button Content="Xem việc cần làm" Width="135" Height="32" Margin="0,0,8,0" Click="btnOpenTasks_Click"/><Button Content="Đã hiểu" Width="90" Height="32" IsDefault="True" Click="btnClose_Click"/></StackPanel>
        </Grid>
    </Border>
</Window>
