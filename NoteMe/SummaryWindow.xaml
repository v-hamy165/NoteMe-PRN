<Window x:Class="NoteMe.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - AI Summary"
        Height="680"
        Width="1050"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Top bar: Note Title and Generator Control -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Area -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==========================================
             TOP CARD - BỘ ĐIỀU KHIỂN TẠO TÓM TẮT AI
             ========================================== -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="16"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="txtNoteTitle"
                               Text="Tiêu đề ghi chú"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Nguồn tóm tắt:"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,0,8,0"/>

                        <ComboBox x:Name="cboSource"
                                  Width="320"
                                  Height="34"
                                  Margin="0,0,12,0"/>

                        <Button x:Name="btnGenerate"
                                Content="🤖 Tạo tóm tắt AI"
                                Width="150"
                                Height="34"
                                Background="#8E44AD"
                                Foreground="White"
                                FontWeight="Bold"
                                Click="btnGenerate_Click"/>

                        <ProgressBar x:Name="progressBar"
                                     Width="120"
                                     Height="6"
                                     Margin="12,0,0,0"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="txtStatus"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="#64748B"
                               Text="Chọn nguồn rồi bấm 'Tạo tóm tắt AI'."/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==========================================
             MAIN CONTENT - GRID HAI CỘT
             ========================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Cột trái: Bản tóm tắt đã lưu (Sidebar) -->
                <ColumnDefinition Width="340"/>
                <!-- Cột phải: Hiển thị Chi tiết tóm tắt AI -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI - DANH SÁCH BẢN TÓM TẮT -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="#000000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Các bản tóm tắt đã lưu"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgSummaries"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              BorderThickness="1"
                              BorderBrush="#E2E8F0"
                              SelectionChanged="dgSummaries_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ngày tạo"
                                                Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}"
                                                Width="130"/>
                            <DataGridTextColumn Header="Nguồn bản ghi"
                                                Binding="{Binding AudioFileName}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnExportPdf"
                                Grid.Column="0"
                                Content="📄 Xuất PDF"
                                Height="34"
                                Background="#3B82F6"
                                Foreground="White"
                                Margin="0,0,4,0"
                                Click="btnExportPdf_Click"/>

                        <Button x:Name="btnDeleteSummary"
                                Grid.Column="1"
                                Content="❌ Xóa tóm tắt"
                                Height="34"
                                Background="#EF4444"
                                Foreground="White"
                                Margin="4,0,0,0"
                                Click="btnDeleteSummary_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- CỘT PHẢI - CHI TIẾT NỘI DUNG TÓM TẮT -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="#000000"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock Text="Nội dung tóm tắt từ AI"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,16"/>

                        <!-- Nội dung chính -->
                        <TextBlock Text="Nội dung chính"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtMainContent"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="100"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16"/>

                        <!-- Các việc đã làm -->
                        <TextBlock Text="Các việc đã làm"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtCompletedSteps"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16"/>

                        <!-- Các bước tiếp theo -->
                        <TextBlock Text="Các bước tiếp theo"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNextSteps"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,8"/>

                        <Button x:Name="btnCreateTasksFromAi"
                                Content="✓ Tạo công việc từ AI"
                                Height="36"
                                HorizontalAlignment="Left"
                                Padding="16,0"
                                Margin="0,0,0,20"
                                Background="#7C3AED"
                                Foreground="White"
                                FontWeight="Bold"
                                Click="btnCreateTasksFromAi_Click"/>

                        <!-- Bản ghi lời thoại -->
                        <Expander Header="Bản ghi lời thoại (transcript)"
                                  FontSize="13"
                                  FontWeight="Bold"
                                  Foreground="#1E293B"
                                  Background="White"
                                  Margin="0,0,0,10">
                            <TextBox x:Name="txtTranscript"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     FontWeight="Normal"
                                     MinHeight="120"
                                     MaxHeight="300"
                                     Background="#F8FAFC"
                                     BorderBrush="#E2E8F0"
                                     Margin="0,8,0,0"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
