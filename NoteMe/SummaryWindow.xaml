<Window x:Class="NoteMe.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - AI Summary"
        Height="640"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtNoteTitle"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Nguồn tóm tắt:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="cboSource"
                          Width="320"
                          Height="30"
                          Margin="0,0,10,0"/>

                <Button x:Name="btnGenerate"
                        Content="Tạo tóm tắt AI"
                        Width="130"
                        Height="30"
                        FontWeight="Bold"
                        Click="btnGenerate_Click"/>

                <ProgressBar x:Name="progressBar"
                             Width="120"
                             Height="10"
                             Margin="10,0,0,0"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="txtStatus"
                       Margin="0,8,0,0"
                       Foreground="Gray"
                       Text="Chọn nguồn rồi bấm 'Tạo tóm tắt AI'."/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Các bản tóm tắt đã lưu"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <DataGrid x:Name="dgSummaries"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="dgSummaries_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày tạo"
                                            Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}"
                                            Width="130"/>

                        <DataGridTextColumn Header="Nguồn"
                                            Binding="{Binding AudioFileName}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Margin="0,10,0,0">
                    <Button x:Name="btnExportPdf"
                            Content="Xuất PDF"
                            Width="110"
                            Height="32"
                            Click="btnExportPdf_Click"/>

                    <Button x:Name="btnDeleteSummary"
                            Content="Xóa tóm tắt"
                            Width="110"
                            Height="32"
                            Margin="10,0,0,0"
                            Click="btnDeleteSummary_Click"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Nội dung chính"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtMainContent"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MinHeight="90"
                             Margin="0,5,0,12"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Các việc đã làm"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtCompletedSteps"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MinHeight="70"
                             Margin="0,5,0,12"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Các bước tiếp theo"
                               FontWeight="Bold"/>

                    <TextBox x:Name="txtNextSteps"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             MinHeight="70"
                             Margin="0,5,0,12"
                             VerticalScrollBarVisibility="Auto"/>

                    <Expander Header="Bản ghi lời thoại (transcript)"
                              FontWeight="Bold"
                              Margin="0,0,0,10">
                        <TextBox x:Name="txtTranscript"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontWeight="Normal"
                                 MinHeight="120"
                                 MaxHeight="300"
                                 Margin="0,5,0,0"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
