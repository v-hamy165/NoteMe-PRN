<Window x:Class="NoteMe.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - Dashboard"
        Height="680"
        Width="980"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Card style: rounded border with drop shadow feel -->
        <Style x:Key="StatCardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.18" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label inside a card -->
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFFFFFCC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Big number inside a card -->
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Quick-action button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F4F6F9">
        <Grid.RowDefinitions>
            <!-- Header bar -->
            <RowDefinition Height="64"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Quick-action footer -->
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════
             ROW 0 – Header
             ════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#0F172A">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="📋"
                               FontSize="26"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Dashboard"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="txtWelcome"
                                   FontSize="12"
                                   Foreground="#AACCEE"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="btnRefresh"
                            Content="🔄  Làm mới"
                            Style="{StaticResource ActionButton}"
                            Background="#3B82F6"
                            Foreground="White"
                            Margin="0,0,8,0"
                            Click="btnRefresh_Click"/>

                    <Button x:Name="btnLogout"
                            Content="🚪  Đăng xuất"
                            Style="{StaticResource ActionButton}"
                            Background="#EF4444"
                            Foreground="White"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════
             ROW 1 – Main content (stat cards + data grids)
             ════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <!-- Left: stat cards -->
                <ColumnDefinition Width="240"/>
                <!-- Right: data grids -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left column: 4 stat cards ── -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">

                <!-- Total Notes -->
                <Border Style="{StaticResource StatCardBorder}"
                        Background="#3498DB">
                    <StackPanel>
                        <TextBlock Text="📝  Tổng ghi chú"
                                   Style="{StaticResource CardLabel}"/>
                        <TextBlock x:Name="txtTotalNotes"
                                   Text="0"
                                   Style="{StaticResource CardValue}"/>
                    </StackPanel>
                </Border>

                <!-- Total Categories -->
                <Border Style="{StaticResource StatCardBorder}"
                        Background="#27AE60">
                    <StackPanel>
                        <TextBlock Text="🗂️  Danh mục"
                                   Style="{StaticResource CardLabel}"/>
                        <TextBlock x:Name="txtTotalCategories"
                                   Text="0"
                                   Style="{StaticResource CardValue}"/>
                    </StackPanel>
                </Border>

                <!-- Total Audio Recordings -->
                <Border Style="{StaticResource StatCardBorder}"
                        Background="#E67E22">
                    <StackPanel>
                        <TextBlock Text="🎙️  Ghi âm"
                                   Style="{StaticResource CardLabel}"/>
                        <TextBlock x:Name="txtTotalAudio"
                                   Text="0"
                                   Style="{StaticResource CardValue}"/>
                    </StackPanel>
                </Border>

                <!-- Total AI Summaries -->
                <Border Style="{StaticResource StatCardBorder}"
                        Background="#8E44AD">
                    <StackPanel>
                        <TextBlock Text="🤖  Tóm tắt AI"
                                   Style="{StaticResource CardLabel}"/>
                        <TextBlock x:Name="txtTotalSummaries"
                                   Text="0"
                                   Style="{StaticResource CardValue}"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ── Right column: latest notes + category stats + recent activities ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- Latest Notes -->
                    <RowDefinition Height="*"/>
                    <!-- Spacer -->
                    <RowDefinition Height="12"/>
                    <!-- Category Stats -->
                    <RowDefinition Height="*"/>
                    <!-- Spacer -->
                    <RowDefinition Height="12"/>
                    <!-- Recent Activities -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Latest 5 Notes -->
                <Border Grid.Row="0"
                        Background="White"
                        CornerRadius="8"
                        Padding="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="🕐  5 Ghi chú gần nhất"
                                   Style="{StaticResource SectionHeader}"/>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="dgLatestNotes"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBFD"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      MouseDoubleClick="dgLatestNotes_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tiêu đề"
                                                        Binding="{Binding Title}"
                                                        Width="2*"/>
                                    <DataGridTextColumn Header="Danh mục"
                                                        Binding="{Binding Category}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Ngày tạo"
                                                        Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Cập nhật cuối"
                                                        Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                        Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <TextBlock x:Name="lblNoNotes"
                                       Text="📭 Không có ghi chú nào."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#888888"
                                       FontSize="13"
                                       FontStyle="Italic"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Category Statistics -->
                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="8"
                        Padding="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="📊  Thống kê theo danh mục"
                                   Style="{StaticResource SectionHeader}"/>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="dgCategoryStats"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBFD"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Danh mục"
                                                        Binding="{Binding Name}"
                                                        Width="2*"/>
                                    <DataGridTextColumn Header="Số ghi chú"
                                                        Binding="{Binding NoteCount}"
                                                        Width="*"/>
                                    <DataGridTemplateColumn Header="Tỷ lệ" Width="180">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,2">
                                                    <ProgressBar Value="{Binding Percentage}" Maximum="100" Height="14" Foreground="#27AE60" Background="#E5E9F0" BorderThickness="0"/>
                                                    <TextBlock Text="{Binding Percentage, StringFormat={}{0:0.0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="#333333"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="lblNoCategories"
                                       Text="📭 Không tìm thấy danh mục nào."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#888888"
                                       FontSize="13"
                                       FontStyle="Italic"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Recent Activities -->
                <Border Grid.Row="4"
                        Background="White"
                        CornerRadius="8"
                        Padding="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.10" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="🔔  Hoạt động gần đây"
                                   Style="{StaticResource SectionHeader}"/>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="dgRecentActivities"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F9FBFD"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Thời gian"
                                                        Binding="{Binding Timestamp, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Loại"
                                                        Binding="{Binding ActivityType}"
                                                        Width="100"/>
                                    <DataGridTextColumn Header="Chi tiết hoạt động"
                                                        Binding="{Binding Description}"
                                                        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="lblNoActivities"
                                       Text="📭 Chưa có hoạt động nào được ghi nhận."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#888888"
                                       FontSize="13"
                                       FontStyle="Italic"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════
             ROW 2 – Quick-action footer
             ════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">

                    <TextBlock Text="Thao tác nhanh:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="#555555"
                               Margin="0,0,10,0"/>

                    <Button x:Name="btnNewNote"
                            Content="✏️ Ghi chú mới"
                            Style="{StaticResource ActionButton}"
                            Background="#10B981"
                            Foreground="White"
                            Margin="0,0,6,0"
                            Click="btnNewNote_Click"/>

                    <Button x:Name="btnManageNotes"
                            Content="📋 Quản lý ghi chú"
                            Style="{StaticResource ActionButton}"
                            Background="#3B82F6"
                            Foreground="White"
                            Margin="0,0,6,0"
                            Click="btnManageNotes_Click"/>

                    <Button x:Name="btnOpenCategories"
                            Content="🗂️ Quản lý danh mục"
                            Style="{StaticResource ActionButton}"
                            Background="#0D9488"
                            Foreground="White"
                            Margin="0,0,6,0"
                            Click="btnOpenCategories_Click"/>

                    <Button x:Name="btnRecordAudio"
                            Content="🎙️ Ghi âm"
                            Style="{StaticResource ActionButton}"
                            Background="#E67E22"
                            Foreground="White"
                            Margin="0,0,6,0"
                            Click="btnRecordAudio_Click"/>

                    <Button x:Name="btnAiSummary"
                            Content="🤖 Tóm tắt AI"
                            Style="{StaticResource ActionButton}"
                            Background="#8B5CF6"
                            Foreground="White"
                            Margin="0,0,6,0"
                            Click="btnAiSummary_Click"/>

                    <Button x:Name="btnExportPdf"
                            Content="📄 Xuất PDF"
                            Style="{StaticResource ActionButton}"
                            Background="#EF4444"
                            Foreground="White"
                            Margin="0,0,6,0"
                            Click="btnExportPdf_Click"/>

                    <Button x:Name="btnBack"
                            Content="🔙 Quay lại"
                            Style="{StaticResource ActionButton}"
                            Background="#64748B"
                            Foreground="White"
                            Click="btnBack_Click"/>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
