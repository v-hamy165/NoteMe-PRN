<Window x:Class="NoteMe.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Công việc" Height="500" Width="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="10" Padding="22" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" x:Name="txtHeading" Text="Tạo công việc" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                <TextBlock Grid.Row="1" Text="Tiêu đề *" FontWeight="SemiBold" Foreground="#475569"/>
                <TextBox Grid.Row="2" x:Name="txtTitle" Height="36" Margin="0,5,0,8" MaxLength="200" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Row="3" Text="Mô tả" FontWeight="SemiBold" Foreground="#475569"/>
                <TextBox Grid.Row="4" x:Name="txtDescription" Height="55" Margin="0,5,0,8" MaxLength="1000" TextWrapping="Wrap" AcceptsReturn="True"/>
                <Grid Grid.Row="5" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"><TextBlock Text="Hạn hoàn thành *" FontWeight="SemiBold" Foreground="#475569"/><DatePicker x:Name="dpDueDate" Height="34" Margin="0,5,0,0"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Giờ" FontWeight="SemiBold" Foreground="#475569"/><StackPanel Orientation="Horizontal" Margin="0,5,0,0"><ComboBox x:Name="cboDueHour" Width="90" Height="34"/><TextBlock Text=":" VerticalAlignment="Center" Margin="6,0"/><ComboBox x:Name="cboDueMinute" Width="90" Height="34"/></StackPanel></StackPanel>
                </Grid>
                <Grid Grid.Row="6" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="Mức ưu tiên" FontWeight="SemiBold" Foreground="#475569"/><ComboBox x:Name="cboPriority" Height="34" Margin="0,5,0,0" SelectedValuePath="Key"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Trạng thái" FontWeight="SemiBold" Foreground="#475569"/><ComboBox x:Name="cboStatus" Height="34" Margin="0,5,0,0" SelectedValuePath="Key"/></StackPanel>
                </Grid>
                <TextBlock Grid.Row="7"
                           Text="Hệ thống sẽ tự động nhắc trước hạn hoàn thành 1 ngày."
                           Foreground="#64748B"
                           FontStyle="Italic"
                           Margin="0,4,0,0"/>
                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Hủy" Width="100" Height="36" Margin="0,0,8,0" IsCancel="True"/>
                    <Button Content="Lưu công việc" Width="130" Height="36" Background="#2563EB" Foreground="White" FontWeight="Bold" Click="btnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
