<Window x:Class="NoteMe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - Quản lý ghi chú &amp; danh mục"
        Height="700"
        Width="1050"
        MinHeight="650"
        MinWidth="950"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <!-- Sidebar Trái: Danh sách & Tìm kiếm -->
            <ColumnDefinition Width="340"/>
            <!-- Vùng chi tiết Phải: Editor & Công cụ -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==========================================
             CỘT TRÁI - SIDEBAR DANH SÁCH
             ========================================== -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="10"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Bộ lọc & Tìm kiếm -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="📝 Ghi chú của tôi"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Tìm kiếm"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#64748B"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="txtSearch"
                             Height="34"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12"
                             TextChanged="txtSearch_TextChanged"/>

                    <TextBlock Text="Lọc theo danh mục"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#64748B"
                               Margin="0,0,0,4"/>
                    <ComboBox x:Name="cboFilterCategory"
                              Height="34"
                              Margin="0,0,0,12"
                              SelectionChanged="cboFilterCategory_SelectionChanged"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="btnClearFilter"
                                Grid.Column="0"
                                Content="❌ Xóa lọc"
                                Height="34"
                                Background="#64748B"
                                Foreground="White"
                                Margin="0,0,4,6"
                                Click="btnClearFilter_Click"/>

                        <Button x:Name="btnOpenDashboard"
                                Grid.Column="1"
                                Content="📊 Dashboard"
                                Height="34"
                                Background="#8E44AD"
                                Foreground="White"
                                Margin="4,0,0,6"
                                Click="btnOpenDashboard_Click"/>

                        <Button x:Name="btnOpenTasks"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Content="✓ Việc cần làm &amp; nhắc lịch"
                                Height="34"
                                Background="#7C3AED"
                                Foreground="White"
                                Margin="0"
                                Click="btnOpenTasks_Click"/>
                    </Grid>
                </StackPanel>

                <!-- DataGrid danh sách ghi chú -->
                <DataGrid x:Name="dgNotes"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="1"
                          BorderBrush="#E2E8F0"
                          SelectionChanged="dgNotes_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="45"/>
                        <DataGridTextColumn Header="Tiêu đề"
                                            Binding="{Binding Title}"
                                            Width="2*"/>
                        <DataGridTextColumn Header="Danh mục"
                                            Binding="{Binding Category}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ==========================================
             CỘT PHẢI - CHI TIẾT & SOẠN THẢO
             ========================================== -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Form soạn thảo và thao tác -->
                    <RowDefinition Height="*"/>
                    <!-- Panel điều khiển lưu/sửa/xóa dưới cùng -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,16"
                              Padding="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Chi tiết ghi chú"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,16"/>

                        <!-- Tiêu đề -->
                        <TextBlock Text="Tiêu đề ghi chú"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtTitle"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,14"/>

                        <!-- Nội dung -->
                        <TextBlock Text="Nội dung chi tiết"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="#475569"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtContent"
                                 Height="160"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16"/>

                        <!-- Quản lý Danh mục -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Quản lý Danh mục"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,10"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Dropdown chọn danh mục -->
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Chọn danh mục"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#64748B"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox x:Name="cboCategory"
                                                  Height="34"
                                                  SelectedValuePath="Name"
                                                  SelectionChanged="cboCategory_SelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Thêm/Sửa danh mục mới -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Tên danh mục mới"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#64748B"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtNewCategory"
                                                 Height="34"
                                                 VerticalContentAlignment="Center"
                                                 MaxLength="50"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Nút thao tác danh mục: chia đều chiều rộng để không cắt chữ -->
                                <UniformGrid Columns="3" Margin="0,12,0,0">
                                    <Button Content="➕ Thêm danh mục"
                                            MinHeight="40"
                                            Margin="0,0,5,0"
                                            Padding="8,6"
                                            Background="#10B981"
                                            Foreground="White"
                                            Click="btnAddCategory_Click"/>
                                    
                                    <Button Content="✏️ Sửa danh mục"
                                            MinHeight="40"
                                            Margin="5,0"
                                            Padding="8,6"
                                            Background="#3B82F6"
                                            Foreground="White"
                                            Click="btnUpdateCategory_Click"/>
                                    
                                    <Button Content="❌ Xóa danh mục"
                                            MinHeight="40"
                                            Margin="5,0,0,0"
                                            Padding="8,6"
                                            Background="#EF4444"
                                            Foreground="White"
                                            Click="btnDeleteCategory_Click"/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Ghi âm & Tóm tắt AI -->
                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="🎙️ Ghi âm &amp; Tóm tắt AI"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,10"/>

                                <StackPanel Margin="0,0,0,10">
                                    <!-- Trạng thái ghi âm nằm riêng để không tranh chiều rộng với nút -->
                                    <TextBlock x:Name="txtAudioStatus"
                                               Text="Chọn ghi chú để ghi âm hoặc phát lại."
                                               Foreground="#64748B"
                                               FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <UniformGrid Columns="4">
                                        <Button x:Name="btnStartRecording"
                                                Content="🎙️ Bắt đầu ghi"
                                                MinHeight="40"
                                                Margin="0,0,4,0"
                                                Padding="7,6"
                                                Background="#E67E22"
                                                Foreground="White"
                                                Click="btnStartRecording_Click"/>
                                        
                                        <Button x:Name="btnStopRecording"
                                                Content="⏹️ Dừng"
                                                MinHeight="40"
                                                Margin="4,0"
                                                Padding="7,6"
                                                Background="#EF4444"
                                                Foreground="White"
                                                IsEnabled="False"
                                                Click="btnStopRecording_Click"/>
                                        
                                        <Button Content="▶️ Phát"
                                                MinHeight="40"
                                                Margin="4,0"
                                                Padding="7,6"
                                                Background="#10B981"
                                                Foreground="White"
                                                Click="btnPlayAudio_Click"/>
                                        
                                        <Button Content="🤖 Tóm tắt AI"
                                                MinHeight="40"
                                                Margin="4,0,0,0"
                                                Padding="7,6"
                                                Background="#8E44AD"
                                                Foreground="White"
                                                FontWeight="Bold"
                                                Click="btnAiSummary_Click"/>
                                    </UniformGrid>
                                </StackPanel>

                                <!-- Bảng danh sách bản ghi -->
                                <DataGrid x:Name="dgAudios"
                                          Height="120"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          BorderThickness="1"
                                          BorderBrush="#E2E8F0"
                                          SelectionChanged="dgAudios_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="File bản ghi"
                                                            Binding="{Binding FileName}"
                                                            Width="2*"/>
                                        <DataGridTextColumn Header="Ngày ghi âm"
                                                            Binding="{Binding CreatedAt}"
                                                            Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Panel Thao tác chính phía dưới -->
                <Border Grid.Row="1"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,1,0,0"
                        Padding="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Refresh -->
                        <Button Grid.Column="0"
                                Content="🔄 Làm mới form"
                                Width="140"
                                Height="36"
                                Background="#64748B"
                                Foreground="White"
                                HorizontalAlignment="Left"
                                Click="btnClear_Click"/>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="➕ Thêm ghi chú"
                                    Width="130"
                                    Height="36"
                                    Background="#10B981"
                                    Foreground="White"
                                    Click="btnAdd_Click"/>
                            
                            <Button Content="✏️ Sửa ghi chú"
                                    Width="130"
                                    Height="36"
                                    Margin="8,0,0,0"
                                    Background="#3B82F6"
                                    Foreground="White"
                                    Click="btnUpdate_Click"/>
                            
                            <Button Content="❌ Xóa ghi chú"
                                    Width="130"
                                    Height="36"
                                    Margin="8,0,0,0"
                                    Background="#EF4444"
                                    Foreground="White"
                                    Click="btnDelete_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
