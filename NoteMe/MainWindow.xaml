<Window x:Class="NoteMe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteMe - Quản lý ghi chú"
        Height="500"
        Width="850"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="dgNotes"
                  Grid.Column="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionChanged="dgNotes_SelectionChanged"
                  Margin="0,0,10,0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"/>

                <DataGridTextColumn Header="Tiêu đề"
                                    Binding="{Binding Title}"
                                    Width="*"/>

                <DataGridTextColumn Header="Danh mục"
                                    Binding="{Binding Category}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Tiêu đề" FontWeight="Bold"/>

            <TextBox x:Name="txtTitle"
                     Height="30"
                     Margin="0,5,0,10"/>

            <TextBlock Text="Nội dung" FontWeight="Bold"/>

            <TextBox x:Name="txtContent"
                     Height="150"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,5,0,10"/>

            <TextBlock Text="Danh mục" FontWeight="Bold"/>

            <ComboBox x:Name="cboCategory"
                      Height="30"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      SelectionChanged="cboCategory_SelectionChanged"
                      Margin="0,5,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox x:Name="txtNewCategory"
                         Width="170"
                         Height="30"
                         MaxLength="50"
                         Margin="0,0,10,0"/>

                <Button Content="Thêm danh mục"
                        Width="100"
                        Height="30"
                        Click="btnAddCategory_Click"/>

                <Button Content="Sửa danh mục"
                        Width="100"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="btnUpdateCategory_Click"/>

                <Button Content="Xóa danh mục"
                        Width="100"
                        Height="30"
                        Margin="8,0,0,0"
                        Click="btnDeleteCategory_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="Thêm"
                        Width="90"
                        Height="35"
                        Click="btnAdd_Click"/>

                <Button Content="Sửa"
                        Width="90"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="btnUpdate_Click"/>

                <Button Content="Xóa"
                        Width="90"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="btnDelete_Click"/>

                <Button Content="Làm mới"
                        Width="90"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="btnClear_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
